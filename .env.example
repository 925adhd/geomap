# Google Maps Platform — Places API (New). Used by /api/places for the
# 49-call scan loop (Essentials tier) and the 1-call business picker
# (Enterprise tier when includeRatings is set).
GOOGLE_PLACES_API_KEY=your_key_here

# Optional: hard monthly USD cap on Places API spend. Default 25.
# When estimated MTD spend hits this, /api/places returns 503 +
# code: "budget_exceeded" until the next UTC month rolls over.
# Set to 0 to disable (NOT recommended once exposed publicly).
PLACES_MONTHLY_BUDGET_USD=25

# Resend (https://resend.com) — used by /api/leads to email Kara when
# someone submits the audit form. If any of these are missing, the
# endpoint still accepts the lead and stores it; it just doesn't email.
RESEND_API_KEY=re_your_key_here
LEADS_NOTIFY_EMAIL=kara@studio925.design
LEADS_FROM_EMAIL=audit@studio925.design

# Admin auth for routes that mutate or expose the lead/scan stores
# (/api/scans GET/POST/DELETE, /api/leads GET/DELETE). Generate a long
# random string (e.g. `openssl rand -base64 32`). The dashboard reads
# this from localStorage — visit https://geomap.studio925.design/?adminToken=<value>
# once and the token is captured + the URL is stripped automatically.
ADMIN_TOKEN=generate_a_long_random_string_here
