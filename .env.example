# Google Maps Platform — Places API (New). Used by /api/places for the
# 49-call scan loop (Essentials tier) and the 1-call business picker
# (Enterprise tier when includeRatings is set).
GOOGLE_PLACES_API_KEY=your_key_here

# Optional: hard monthly USD cap on Places API spend. Default 25.
# When estimated MTD spend hits this, /api/places returns 503 +
# code: "budget_exceeded" until the next UTC month rolls over.
# Set to 0 to disable (NOT recommended once exposed publicly).
PLACES_MONTHLY_BUDGET_USD=25

# Resend (https://resend.com) — used by /api/leads to email Kara when
# someone submits the audit form. If any of these are missing, the
# endpoint still accepts the lead and stores it; it just doesn't email.
RESEND_API_KEY=re_your_key_here
LEADS_NOTIFY_EMAIL=kara@studio925.design
LEADS_FROM_EMAIL=audit@studio925.design

# Admin auth for the local dashboard. The /admin route and the admin API
# methods (/api/scans CRUD, /api/leads GET/DELETE) are dev-only — they
# 404 in production builds — so this token is only needed in .env.local.
# Generate a long random string (e.g. `openssl rand -base64 32`). The
# dashboard reads it from localStorage — visit
# http://localhost:3000/?adminToken=<value> once during dev setup.
ADMIN_TOKEN=generate_a_long_random_string_here

# Supabase project credentials. Both are server-only — never NEXT_PUBLIC_.
# - SERVICE_ROLE_KEY bypasses RLS, used by admin/write paths.
# - ANON_KEY respects RLS, used by the public /report/[timestamp] page.
#   The only RLS policy in the project grants SELECT on `scans` to anon,
#   so the anon key can read scans and nothing else.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi_your_service_role_jwt_here
SUPABASE_ANON_KEY=eyJhbGciOi_your_anon_jwt_here
